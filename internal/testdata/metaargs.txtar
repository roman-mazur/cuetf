env HOME=$WORK/_home

exec cue export . -f -o input.tf.json

-- cue.mod/module.cue --
module: "mod.example"
language: {
	version: "v0.17.0"
}
deps: {
	"github.com/roman-mazur/cuetf/providers/github@v0": {
		v:       "v0.2607.2"
		default: true
	}
}
-- example.cue --
package example

import gh "github.com/roman-mazur/cuetf/providers/github"

gh.#Terraform

resource: github_repository: cue: {
	name: "test"
	lifecycle: prevent_destroy: true
}
