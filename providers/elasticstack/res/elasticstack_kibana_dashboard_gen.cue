package res

#elasticstack_kibana_dashboard: {
	@jsonschema(schema="https://json-schema.org/draft/2020-12/schema")
	@jsonschema(id="https://github.com/roman-mazur/cuetf/schema/res/elasticstack_kibana_dashboard")
	close({
		// Access control parameters for the dashboard.
		access_control?: close({
			// The access mode for the dashboard (e.g., 'write_restricted',
			// 'default').
			access_mode?: string
		})

		// The Kibana-assigned identifier for the dashboard.
		dashboard_id?: string

		// A short description of the dashboard.
		description?: string

		// Dashboard-level saved filter pills
		// (`kbn-dashboard-data.filters` in the Kibana Dashboard API).
		// Each element is one filter in display order. The JSON shape
		// for each `filter_json` matches the dashboard filters
		// discriminated union (including DSL and spatial variants),
		// consistent with per-panel `filter_json` on Lens chart blocks.
		filters?: matchN(1, [close({
			// One dashboard saved filter as normalized JSON. Must be a JSON
			// object matching the Kibana dashboard filters union (for
			// example `operator`-based filters, groups, DSL, or spatial
			// shapes) described in the dashboards OpenAPI specification—same
			// union as chart-level `filter_json`.
			filter_json!: string
		}), [...close({
			// One dashboard saved filter as normalized JSON. Must be a JSON
			// object matching the Kibana dashboard filters union (for
			// example `operator`-based filters, groups, DSL, or spatial
			// shapes) described in the dashboards OpenAPI specification—same
			// union as chart-level `filter_json`.
			filter_json!: string
		})]])

		// Generated composite identifier for the dashboard.
		id?: string

		// Display options for the dashboard.
		options?: close({
			// When true, control filters are applied automatically.
			auto_apply_filters?: bool

			// When true, panel borders are hidden in the dashboard layout.
			hide_panel_borders?: bool

			// Hide the panel titles in the dashboard.
			hide_panel_titles?: bool

			// Synchronize colors between related panels in the dashboard.
			sync_colors?: bool

			// Synchronize cursor position between related panels in the
			// dashboard.
			sync_cursor?: bool

			// Synchronize tooltips between related panels in the dashboard.
			sync_tooltips?: bool

			// Show margins between panels in the dashboard layout.
			use_margins?: bool
		})

		// The panels to display in the dashboard.
		panels?: matchN(1, [close({
			// The configuration of the panel as a JSON string.
			// Practitioner-authored panel-level `config_json` is valid only
			// when `type` is `markdown` or `vis`. Typed panel kinds such as
			// `image`, `slo_alerts`, and `discover_session` use their
			// dedicated blocks (`image_config`, `slo_alerts_config`,
			// `discover_session_config`), not panel-level `config_json`.
			// Mutually exclusive with `slo_burn_rate_config`,
			// `slo_error_budget_config`, `slo_overview_config`,
			// `synthetics_monitors_config`,
			// `synthetics_stats_overview_config`,
			// `time_slider_control_config`, `options_list_control_config`,
			// `range_slider_control_config`, `esql_control_config`,
			// `markdown_config`, `image_config`, `slo_alerts_config`,
			// `vis_config`, `discover_session_config`.
			config_json?: string

			// The identifier of the panel (API `id`).
			id?: string

			// The type of the panel (e.g. 'markdown', 'vis').
			type!: string

			// Configuration for a `discover_session` panel
			// (`kbn-dashboard-panel-type-discover_session`). Set exactly one
			// of `by_value` or `by_reference`. Mutually exclusive with
			// `config_json`, `slo_burn_rate_config`,
			// `slo_error_budget_config`, `slo_overview_config`,
			// `synthetics_monitors_config`,
			// `synthetics_stats_overview_config`,
			// `time_slider_control_config`, `options_list_control_config`,
			// `range_slider_control_config`, `esql_control_config`,
			// `markdown_config`, `image_config`, `slo_alerts_config`,
			// `vis_config`.
			discover_session_config?: close({
				// Reference an existing Discover session saved object via
				// `ref_id`. Client-side `references` JSON is not modeled in v1
				// (see change design). Omit `selected_tab_id` to let Kibana pick
				// the tab; after apply the resolved id is stored in state.
				by_reference?: close({
					// Optional typed presentation overrides applied on top of the
					// referenced session.
					overrides?: close({
						// Overrides column order relative to the referenced Discover
						// session.
						column_order?: [...string]

						// Overrides data grid density.
						density?: string

						// Overrides header row height: numbers "1"–"5" or "auto".
						header_row_height?: string

						// Overrides data row height: numbers "1"–"20" or "auto".
						row_height?: string

						// Overrides rows per page.
						rows_per_page?: number

						// Overrides sample size.
						sample_size?: number

						// Per-column presentation settings keyed by field name (for
						// example column widths).
						column_settings?: [string]: close({
							// Optional column width in pixels.
							width?: number
						})

						// Overrides sort configuration relative to the referenced
						// Discover session.
						sort?: matchN(1, [close({
							// Sort direction.
							direction!: string

							// Field name to sort by.
							name!: string
						}), [...close({
							// Sort direction.
							direction!: string

							// Field name to sort by.
							name!: string
						})]])
					})

					// Discover session saved object reference id (`ref_id` in the
					// API).
					ref_id!: string

					// Tab id within the referenced Discover session. Omit to let
					// Kibana choose; after apply the API value is reflected here.
					selected_tab_id?: string

					// Optional time range for this panel. When omitted, the dashboard
					// root `time_range` is sent to the API at write time while this
					// attribute stays null in state (REQ-009).
					time_range?: close({
						// Start of the time range (e.g., 'now-15m',
						// '2023-01-01T00:00:00Z').
						from!: string

						// Optional time range mode. When set, must be `absolute` or
						// `relative`.
						mode?: string

						// End of the time range (e.g., 'now', '2023-12-31T23:59:59Z').
						to!: string
					})
				})

				// Inline Discover session configuration
				// (`kbn-dashboard-panel-type-discover_session` config branch
				// `0`). Set `tab` with exactly one of `dsl` (data view + query)
				// or `esql`. The API currently restricts Discover tabs to
				// **one** entry, so Terraform exposes a single `tab` object (not
				// `tabs = [...]`); if Kibana raises that limit, a list-based
				// shape could be added later without breaking existing
				// configurations. Omit `time_range` to inherit the dashboard
				// root time range at write time while keeping this block null in
				// Terraform state.
				by_value?: close({
					// Single Discover tab configuration (the API currently allows one
					// tab). Exactly one of `dsl` or `esql` must be set.
					tab!: close({
						// DSL / data view Discover tab.
						dsl?: close({
							// Ordered list of field names shown in the Discover grid.
							column_order?: [...string]

							// Normalized JSON for the tab `data_source` field. Author an
							// object that matches the **Kibana Dashboard API** schema for
							// `kbn-dashboard-panel-type-discover_session` tabs: for
							// `tab.dsl`, the polymorphic DSL data-source union
							// (`data_view_reference`, `data_view_spec`, etc. — see the
							// OpenAPI bundled with the [Kibana REST API
							// reference](https://www.elastic.co/docs/api/doc/kibana)); for
							// `tab.esql`, use the ES|QL data-source shape (`type = "esql"`
							// plus query and related fields).
							//
							// Use **`ref_id`** for `data_view_reference` links (not `id`).
							// Semantic JSON equality suppresses drift from key ordering or
							// whitespace.
							data_source_json!: string

							// Data grid density.
							density?: string

							// Header row height: numbers "1"–"5" (as decimal strings) or
							// "auto".
							header_row_height?: string

							// Data row height: numbers "1"–"20" (as decimal strings) or
							// "auto".
							row_height?: string

							// Rows per page in the Discover grid.
							rows_per_page?: number

							// Sample size (documents) for the Discover grid.
							sample_size?: number

							// Discover view mode for the DSL tab: `documents` (hits),
							// `patterns`, or `aggregated` (field statistics). Matches the
							// Kibana Dashboard API enum values.
							view_mode?: string

							// Per-column presentation settings keyed by field name (for
							// example column widths).
							column_settings?: [string]: close({
								// Optional column width in pixels.
								width?: number
							})

							// Optional Discover filters for the DSL tab. Each element is
							// API-shaped filter JSON (`filter_json`), matching
							// dashboard-root `filters` and chart filters (REQ-037).
							filters?: matchN(1, [close({
								// Chart filter as normalized JSON. Must match the Kibana
								// dashboard API for this chart: one of the filter union members
								// (condition, group, DSL, or spatial) described in the
								// dashboards OpenAPI specification.
								filter_json!: string
							}), [...close({
								// Chart filter as normalized JSON. Must match the Kibana
								// dashboard API for this chart: one of the filter union members
								// (condition, group, DSL, or spatial) described in the
								// dashboards OpenAPI specification.
								filter_json!: string
							})]])

							// Kibana query used by this DSL Discover tab (KQL or Lucene).
							query!: close({
								// Filter expression string.
								expression!: string

								// Query language (default: 'kql').
								language?: string
							})

							// Sort configuration for the Discover grid.
							sort?: matchN(1, [close({
								// Sort direction.
								direction!: string

								// Field name to sort by.
								name!: string
							}), [...close({
								// Sort direction.
								direction!: string

								// Field name to sort by.
								name!: string
							})]])
						})

						// ES|QL Discover tab.
						esql?: close({
							// Ordered list of field names shown in the Discover grid.
							column_order?: [...string]

							// Normalized JSON for the tab `data_source` field. Author an
							// object that matches the **Kibana Dashboard API** schema for
							// `kbn-dashboard-panel-type-discover_session` tabs: for
							// `tab.dsl`, the polymorphic DSL data-source union
							// (`data_view_reference`, `data_view_spec`, etc. — see the
							// OpenAPI bundled with the [Kibana REST API
							// reference](https://www.elastic.co/docs/api/doc/kibana)); for
							// `tab.esql`, use the ES|QL data-source shape (`type = "esql"`
							// plus query and related fields).
							//
							// Use **`ref_id`** for `data_view_reference` links (not `id`).
							// Semantic JSON equality suppresses drift from key ordering or
							// whitespace.
							data_source_json!: string

							// Data grid density.
							density?: string

							// Header row height: numbers "1"–"5" (as decimal strings) or
							// "auto".
							header_row_height?: string

							// Data row height: numbers "1"–"20" (as decimal strings) or
							// "auto".
							row_height?: string

							// Per-column presentation settings keyed by field name (for
							// example column widths).
							column_settings?: [string]: close({
								// Optional column width in pixels.
								width?: number
							})

							// Sort configuration for the Discover grid.
							sort?: matchN(1, [close({
								// Sort direction.
								direction!: string

								// Field name to sort by.
								name!: string
							}), [...close({
								// Sort direction.
								direction!: string

								// Field name to sort by.
								name!: string
							})]])
						})
					})

					// Optional time range for this panel. When omitted, the dashboard
					// root `time_range` is sent to the API at write time while this
					// attribute stays null in state (REQ-009).
					time_range?: close({
						// Start of the time range (e.g., 'now-15m',
						// '2023-01-01T00:00:00Z').
						from!: string

						// Optional time range mode. When set, must be `absolute` or
						// `relative`.
						mode?: string

						// End of the time range (e.g., 'now', '2023-12-31T23:59:59Z').
						to!: string
					})
				})

				// Optional panel description.
				description?: string

				// Typed URL drilldowns for this panel. The API only supports
				// `url_drilldown` with trigger `on_open_panel_menu`; those
				// values are set automatically when writing to Kibana.
				drilldowns?: matchN(1, [close({
					// When true, the URL is percent-encoded.
					encode_url?: bool

					// The display label for the drilldown link.
					label!: string

					// When true, the drilldown URL opens in a new browser tab.
					open_in_new_tab?: bool

					// The URL template for the drilldown. Variables are documented at
					// https://www.elastic.co/docs/explore-analyze/dashboards/drilldowns#url-template-variable.
					url!: string
				}), [...close({
					// When true, the URL is percent-encoded.
					encode_url?: bool

					// The display label for the drilldown link.
					label!: string

					// When true, the drilldown URL opens in a new browser tab.
					open_in_new_tab?: bool

					// The URL template for the drilldown. Variables are documented at
					// https://www.elastic.co/docs/explore-analyze/dashboards/drilldowns#url-template-variable.
					url!: string
				})]])

				// When true, suppresses the panel border.
				hide_border?: bool

				// When true, suppresses the panel title.
				hide_title?: bool

				// Optional panel title.
				title?: string
			})

			// Configuration for an ES|QL control panel. Use this to manage
			// ES|QL variable controls on a dashboard. Mutually exclusive
			// with `config_json`, `slo_burn_rate_config`,
			// `slo_error_budget_config`, `slo_overview_config`,
			// `synthetics_monitors_config`,
			// `synthetics_stats_overview_config`,
			// `time_slider_control_config`, `options_list_control_config`,
			// `range_slider_control_config`, `markdown_config`,
			// `image_config`, `slo_alerts_config`, `vis_config`,
			// `discover_session_config`.
			esql_control_config?: close({
				// Pre-populated list of available options shown before the query
				// executes.
				available_options?: [...string]

				// The control type. Allowed values: `STATIC_VALUES`,
				// `VALUES_FROM_QUERY`.
				control_type!: string

				// The ES|QL query used to populate the control's options.
				esql_query!: string

				// List of currently selected option values for the control.
				selected_options!: [...string]

				// When true, restricts the control to single-value selection.
				single_select?: bool

				// A human-readable title displayed above the control widget.
				title?: string

				// The ES|QL variable name that this control binds to.
				variable_name!: string

				// The type of ES|QL variable. Allowed values: `fields`, `values`,
				// `functions`, `time_literal`, `multi_values`.
				variable_type!: string

				// Display configuration for the control widget.
				display_settings?: close({
					// Whether to hide the action bar on the control.
					hide_action_bar?: bool

					// Whether to hide the exclude option.
					hide_exclude?: bool

					// Whether to hide the exists filter option.
					hide_exists?: bool

					// Whether to hide the sort option.
					hide_sort?: bool

					// Placeholder text shown when no option is selected.
					placeholder?: string
				})
			})

			// The grid coordinates and dimensions of the panel.
			grid!: close({
				// The height.
				h?: number

				// The width.
				w?: number

				// The X coordinate.
				x!: number

				// The Y coordinate.
				y!: number
			})

			// Configuration for an `image` panel
			// (`kbn-dashboard-panel-type-image`). Required when `type` is
			// `image`. References the Kibana Dashboard API image embeddable
			// `config` shape. Mutually exclusive with `config_json`,
			// `slo_burn_rate_config`, `slo_error_budget_config`,
			// `slo_overview_config`, `synthetics_monitors_config`,
			// `synthetics_stats_overview_config`,
			// `time_slider_control_config`, `options_list_control_config`,
			// `range_slider_control_config`, `esql_control_config`,
			// `markdown_config`, `slo_alerts_config`, `vis_config`,
			// `discover_session_config`.
			image_config?: close({
				// Accessible alternate text for the image.
				alt_text?: string

				// Background color behind the image (CSS color string).
				background_color?: string

				// Optional panel description.
				description?: string

				// When true, hides the panel border.
				hide_border?: bool

				// When true, hides the panel title.
				hide_title?: bool

				// How the image is sized within its panel container. Omit to
				// leave unset; the Kibana API defaults to `contain`. Unset
				// values stay null in Terraform state when the API echoes that
				// default (REQ-009).
				object_fit?: string

				// Optional panel title shown in the panel header.
				title?: string

				// Optional drilldown actions for the image panel (max 100
				// entries). Each element sets exactly one of
				// `dashboard_drilldown` or `url_drilldown`, matching the Kibana
				// `kbn-dashboard-panel-type-image` `config.drilldowns`
				// discriminated union.
				drilldowns?: matchN(1, [close({
					// Open another dashboard when the image is clicked. Mutually
					// exclusive with `url_drilldown` in the same entry.
					dashboard_drilldown?: close({
						// Target dashboard saved object id.
						dashboard_id!: string

						// Label shown for this drilldown.
						label!: string

						// When true, opens the target dashboard in a new browser tab.
						// Omit for API default (typically `false`).
						open_in_new_tab?: bool

						// Dashboard drilldowns on image panels only support
						// `on_click_image` (see Kibana `kbn-dashboard-panel-type-image`
						// drilldown schema).
						trigger!: string

						// When true, passes the current dashboard filters to the opened
						// dashboard. Omit for API default (typically `false`).
						use_filters?: bool

						// When true, passes the current time range to the opened
						// dashboard. Omit for API default (typically `false`).
						use_time_range?: bool
					})

					// URL drilldown entry. Mutually exclusive with
					// `dashboard_drilldown` in the same list element.
					url_drilldown?: close({
						// When true, the URL is percent-encoded. Omit to use the API
						// default; unset stays null when the API echoes the default
						// (REQ-009).
						encode_url?: bool

						// Display label shown in the drilldown menu.
						label!: string

						// When true, opens in a new browser tab. Omit to use the API
						// default; unset stays null when the API echoes the default
						// (REQ-009).
						open_in_new_tab?: bool

						// When this drilldown runs. Allowed values: `on_click_image`,
						// `on_open_panel_menu` (Kibana image panel URL drilldown
						// triggers).
						trigger!: string

						// Templated URL for the drilldown. Variables are documented in
						// the [Kibana drilldown URL template
						// variables](https://www.elastic.co/docs/explore-analyze/dashboards/drilldowns#url-template-variable)
						// section of the Elastic docs.
						url!: string
					})
				}), [...close({
					// Open another dashboard when the image is clicked. Mutually
					// exclusive with `url_drilldown` in the same entry.
					dashboard_drilldown?: close({
						// Target dashboard saved object id.
						dashboard_id!: string

						// Label shown for this drilldown.
						label!: string

						// When true, opens the target dashboard in a new browser tab.
						// Omit for API default (typically `false`).
						open_in_new_tab?: bool

						// Dashboard drilldowns on image panels only support
						// `on_click_image` (see Kibana `kbn-dashboard-panel-type-image`
						// drilldown schema).
						trigger!: string

						// When true, passes the current dashboard filters to the opened
						// dashboard. Omit for API default (typically `false`).
						use_filters?: bool

						// When true, passes the current time range to the opened
						// dashboard. Omit for API default (typically `false`).
						use_time_range?: bool
					})

					// URL drilldown entry. Mutually exclusive with
					// `dashboard_drilldown` in the same list element.
					url_drilldown?: close({
						// When true, the URL is percent-encoded. Omit to use the API
						// default; unset stays null when the API echoes the default
						// (REQ-009).
						encode_url?: bool

						// Display label shown in the drilldown menu.
						label!: string

						// When true, opens in a new browser tab. Omit to use the API
						// default; unset stays null when the API echoes the default
						// (REQ-009).
						open_in_new_tab?: bool

						// When this drilldown runs. Allowed values: `on_click_image`,
						// `on_open_panel_menu` (Kibana image panel URL drilldown
						// triggers).
						trigger!: string

						// Templated URL for the drilldown. Variables are documented in
						// the [Kibana drilldown URL template
						// variables](https://www.elastic.co/docs/explore-analyze/dashboards/drilldowns#url-template-variable)
						// section of the Elastic docs.
						url!: string
					})
				})]])

				// Image source for the panel. Set exactly one nested branch:
				// `file` (uploaded Kibana file id) or `url` (external image
				// URL). Matches the Kibana Dashboard API
				// `kbn-dashboard-panel-type-image` `config.image_config.src`
				// union.
				//
				// For `file.file_id`, Terraform accepts only the string id
				// returned by Kibana after an upload; creating or deleting the
				// uploaded file is **not** handled by this resource today (use
				// the UI, Saved Objects, or HTTP APIs). A dedicated
				// `elasticstack_kibana_file` resource may be introduced later if
				// practitioners need uploads as code.
				src!: close({
					// Use an uploaded file as the image source. Mutually exclusive
					// with `url` inside `src`.
					file?: close({
						// Kibana file identifier for the uploaded image.
						file_id!: string
					})

					// Use an external URL as the image source. Mutually exclusive
					// with `file` inside `src`.
					url?: close({
						// HTTPS or HTTP URL of the image.
						url!: string
					})
				})
			})

			// Configuration for a `markdown` panel (the Kibana Dashboard API
			// `kbn-dashboard-panel-type-markdown` shape). Set exactly one of
			// `by_value` (inline `content` with required nested `settings`)
			// or `by_reference` (existing library item via `ref_id`).
			// Presentation fields (`description`, `hide_title`, `title`,
			// `hide_border`) are supported in both branches. Mutually
			// exclusive with `config_json`, `slo_burn_rate_config`,
			// `slo_error_budget_config`, `slo_overview_config`,
			// `synthetics_monitors_config`,
			// `synthetics_stats_overview_config`,
			// `time_slider_control_config`, `options_list_control_config`,
			// `range_slider_control_config`, `esql_control_config`,
			// `image_config`, `slo_alerts_config`, `vis_config`,
			// `discover_session_config`.
			markdown_config?: close({
				// Reference an existing markdown library item via `ref_id`.
				// Optional `description`, `hide_title`, `title`, and
				// `hide_border`.
				by_reference?: close({
					// Optional panel description.
					description?: string

					// When true, hides the panel border.
					hide_border?: bool

					// When true, hides the panel title.
					hide_title?: bool

					// Unique identifier of the markdown library item (API `ref_id`).
					// The provider does not verify the item exists at plan time.
					ref_id!: string

					// Optional panel title shown in the panel header.
					title?: string
				})

				// Inline markdown: required `content` and nested `settings` (API
				// `settings` object). Optional `description`, `hide_title`,
				// `title`, and `hide_border`.
				by_value?: close({
					// Markdown source for the panel body (API `content`).
					content!: string

					// Optional panel description.
					description?: string

					// When true, hides the panel border.
					hide_border?: bool

					// When true, hides the panel title.
					hide_title?: bool

