		elasticstack_apm_source_map: {
			version: 0
			block: {
				attributes: {
					bundle_filepath: {
						type:             "string"
						description:      "The absolute path of the final bundle as used in the web application (e.g. `/static/js/main.chunk.js`). Must match the path used during the build."
						description_kind: "markdown"
						required:         true
					}
					id: {
						type:             "string"
						description:      "The Fleet artifact ID returned by the APM source map upload API. Used to track the resource across plan/apply cycles."
						description_kind: "markdown"
						computed:         true
					}
					service_name: {
						type:             "string"
						description:      "The name of the APM service that the source map applies to. Must match the `service.name` field in APM events."
						description_kind: "markdown"
						required:         true
					}
					service_version: {
						type:             "string"
						description:      "The version of the APM service that the source map applies to. Must match the `service.version` field in APM events."
						description_kind: "markdown"
						required:         true
					}
					sourcemap: {
						nested_type: {
							attributes: {
								binary: {
									type:             "string"
									description:      "The source map content as a base64-encoded string (standard encoding). Exactly one of `json`, `binary`, or `file.path` must be set. The value is write-only and is not read back from the API."
									description_kind: "markdown"
									optional:         true
									sensitive:        true
								}
								file: {
									nested_type: {
										attributes: {
											checksum: {
												type:             "string"
												description:      "SHA256 hex digest of the uploaded sourcemap."
												description_kind: "markdown"
												computed:         true
											}
											path: {
												type:             "string"
												description:      "Absolute or relative path to the source map file on the local filesystem."
												description_kind: "markdown"
												required:         true
											}
										}
										nesting_mode: "single"
									}
									description:      "Upload a source map from a local file path."
									description_kind: "markdown"
									optional:         true
								}
								json: {
									type:             "string"
									description:      "The source map content as a JSON string. Exactly one of `json`, `binary`, or `file.path` must be set. The value is write-only and is not read back from the API."
									description_kind: "markdown"
									optional:         true
									sensitive:        true
								}
							}
							nesting_mode: "single"
						}
						description:      "The source map content. Exactly one of `json`, `binary`, or `file.path` must be set."
						description_kind: "markdown"
						required:         true
					}
					space_id: {
						type:             "string"
						description:      "The Kibana space ID in which to manage the source map. Omit or set to `\"default\"` for the default space. When set, all API operations are prefixed with `/s/{space_id}`."
						description_kind: "markdown"
						optional:         true
					}
				}
				block_types: kibana_connection: {
					nesting_mode: "list"
					block: {
						attributes: {
							api_key: {
								type:             "string"
								description:      "API Key to use for authentication to Kibana"
								description_kind: "markdown"
								optional:         true
								sensitive:        true
							}
							bearer_token: {
								type:             "string"
								description:      "Bearer Token to use for authentication to Kibana"
								description_kind: "markdown"
								optional:         true
								sensitive:        true
							}
							ca_certs: {
								type: ["list", "string"]
								description:      "A list of paths to CA certificates to validate the certificate presented by the Kibana server."
								description_kind: "markdown"
								optional:         true
							}
							endpoints: {
								type: ["list", "string"]
								description:      "A comma-separated list of endpoints where the terraform provider will point to, this must include the http(s) schema and port number."
								description_kind: "markdown"
								optional:         true
								sensitive:        true
							}
							insecure: {
								type:             "bool"
								description:      "Disable TLS certificate validation"
								description_kind: "markdown"
								optional:         true
							}
							password: {
								type:             "string"
								description:      "Password to use for API authentication to Kibana."
								description_kind: "markdown"
								optional:         true
								sensitive:        true
							}
							username: {
								type:             "string"
								description:      "Username to use for API authentication to Kibana."
								description_kind: "markdown"
								optional:         true
							}
						}
						description:      "Kibana connection configuration block."
						description_kind: "markdown"
					}
				}
				description:      "Uploads and manages an APM source map artifact. Source maps allow APM to un-minify JavaScript stack traces."
				description_kind: "markdown"
			}
		}
